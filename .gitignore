# Ignore everything
*

# Allow essential files
!.gitignore
!README.md
!LICENSE

# Allow root landing page
!index.html

# Allow the shared rendering engine
!app/
!app/**

# Allow product data
!products/
!products/**

# Allow product bootstrap pages (HTML, favicon, og-image only — no js/css/fonts dupes)
!npsp/
!npsp/index.html
!npsp/favicon.svg
!npsp/og-image.png

# Allow future product bootstraps
!revenue/
!revenue/index.html

!eda/
!eda/index.html

# Package config
!package.json
!omnistudio/
!omnistudio/index.html
.gh-token

!educationcloud/
!educationcloud/index.html

!nonprofitcloud/
!nonprofitcloud/index.html

!edassh/
!edassh/index.html
