# Ignore everything
*

# Allow essential files
!.gitignore
!README.md
!LICENSE

# Allow root landing page
!index.html

# Allow the shared rendering engine
!app/
!app/**

# Allow product data
!products/
!products/**

# Allow product bootstrap pages (HTML, favicon, og-image only — no js/css/fonts dupes)
!npsp/
!npsp/index.html
!npsp/favicon.svg
!npsp/og-image.png

# Allow future product bootstraps
!revenue/
!revenue/index.html
!revenue/favicon.svg
!revenue/og-image.png

!eda/
!eda/index.html

# Package config
!package.json
!omnistudio/
!omnistudio/index.html
!omnistudio/favicon.svg
!omnistudio/og-image.png
.gh-token

